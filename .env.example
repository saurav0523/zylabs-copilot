# Database configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zylabs
# For running backend outside docker, use localhost:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zylabs

# Redis configuration
REDIS_URL=redis://redis:6379/0
# For running backend outside docker, use localhost:
# REDIS_URL=redis://localhost:6379/0

# API Keys
FIRECRAWL_API_KEY=fc-your-api-key
ANTHROPIC_API_KEY=sk-ant-your-api-key
# Alternative: OPENAI_API_KEY=sk-your-api-key

# Application Settings
LOG_LEVEL=INFO
MAX_RETRY_COUNT=2
QA_QUALITY_THRESHOLD=0.7
MAX_PAGES_PER_SESSION=10
PORT=8000
HOST=0.0.0.0
