# Database configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zylabs
# For running backend outside docker, use localhost:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zylabs

# Redis configuration
REDIS_URL=redis://redis:6379/0
# For running backend outside docker, use localhost:
# REDIS_URL=redis://localhost:6379/0

# ── Scraping providers ────────────────────────────────────────────────────────
# Tavily (tvly-... key) or Firecrawl (fc-... key) — auto-detected from prefix
FIRECRAWL_API_KEY=fc-your-api-key
# TAVILY_API_KEY=tvly-your-api-key   # optional: explicit Tavily key slot

# ── LLM provider: OpenRouter ──────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-api-key

# Primary model used by each node (override per-node in backend/services/llm.py)
OPENROUTER_PRIMARY_MODEL=deepseek/deepseek-chat-v3-0324:free

# Fallback model on 429 / 503 / timeout
OPENROUTER_FALLBACK_MODEL=qwen/qwen3-32b:free

# ── Per-node model overrides (OPTIONAL — remove # to activate) ────────────────
# Defaults are baked in. Only set these if you want a different model per node.
# NODE_MODEL_PLANNER=qwen/qwen3-32b:free
# NODE_MODEL_ANALYST=deepseek/deepseek-chat-v3-0324:free
# NODE_MODEL_QA=google/gemma-3-27b-it:free
# NODE_MODEL_REPORTER=deepseek/deepseek-chat-v3-0324:free
# NODE_MODEL_CHAT=deepseek/deepseek-chat-v3-0324:free

# ── Application settings ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RETRY_COUNT=2
QA_QUALITY_THRESHOLD=0.7
MAX_PAGES_PER_SESSION=10
PORT=8000
HOST=0.0.0.0
